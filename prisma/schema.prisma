// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STAFF
  PATIENT
  DOCTOR
}

enum AppointmentStatus {
  pending
  confirmed
  done
  cancelled
}

enum SlotStatus {
  free
  booked
}

enum OrderStatus {
  pending
  confirmed
  completed
  cancelled
}

enum DeliveryMethod {
  pickup
  nova_poshta
}

enum NotificationType {
  appointment_status
  order_new
  order_status
}

// ─── Auth.js models ──────────────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  // Bcrypt hash for Credentials provider. NULL means the account was created
  // through OAuth (Google) only and cannot sign in via password.
  passwordHash  String?
  role          Role           @default(PATIENT)
  patientId     String?        @unique
  patient       Patient?       @relation(fields: [patientId], references: [id])
  // Зворотний звʼязок: акаунт лікаря (FK живе на Doctor.userId).
  doctor        Doctor?
  // Замовлення магазину цього користувача (гостьові — з userId = NULL).
  orders        Order[]
  // Сповіщення цього користувача (роль-аваре: пацієнт — про свої записи,
  // staff/admin — про замовлення). Кожен бачить лише свої.
  notifications Notification[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Clinic models ───────────────────────────────────────────────────────────

model Patient {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  // Nullable + unique: Google-реєстрація не збирає телефон (Google його не
  // віддає), а Postgres unique-індекс дозволяє кілька NULL — Google-користувачі
  // не конфліктують. Email-реєстрація завжди зберігає канонічний +380XXXXXXXXX
  // (див. normalizePhone), тож кожен номер належить рівно одному пацієнту.
  phone        String?       @unique
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  user         User?
}

model Doctor {
  id           String             @id @default(cuid())
  name         String
  specialty    String
  // Опційний звʼязок з акаунтом: лікар може мати User для входу в кабінет.
  userId       String?            @unique
  user         User?              @relation(fields: [userId], references: [id])
  createdAt    DateTime           @default(now())
  appointments Appointment[]
  slots        AvailabilitySlot[]
}

model Appointment {
  id        String            @id @default(cuid())
  date      DateTime
  status    AppointmentStatus @default(pending)
  notes     String?
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id])
  doctorId  String
  doctor    Doctor            @relation(fields: [doctorId], references: [id])
  // Зворотний звʼязок: слот доступності, який закрив цей запис (FK на
  // AvailabilitySlot.appointmentId). Без нових колонок у Appointment.
  slot      AvailabilitySlot?
  createdAt DateTime          @default(now())

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
}

// ─── Booking / availability ──────────────────────────────────────────────────

model AvailabilitySlot {
  id            String       @id @default(cuid())
  doctorId      String
  doctor        Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  // UTC. startsAt/endsAt завжди зберігаємо та читаємо як UTC — без TZ-зсувів.
  startsAt      DateTime
  endsAt        DateTime
  status        SlotStatus   @default(free)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([doctorId, startsAt])
  @@index([doctorId, status, startsAt])
}

// ─── Shop ─────────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  // Гроші — Decimal, не Float (без похибок округлення). UAH.
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  category    String?
  stock       Int      @default(0) // залишок; 0 = купити не можна
  // Soft delete: "видалення" товару адміном = isActive=false. Реального DELETE
  // не робимо — інакше зламалися б OrderItem наявних замовлень (FK Restrict).
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@index([isActive])
}

model Order {
  id             String         @id @default(cuid())
  status         OrderStatus    @default(pending)
  deliveryMethod DeliveryMethod
  contactName    String
  contactPhone   String
  // Лише для nova_poshta; для самовивозу лишаються NULL.
  npCity         String?
  npWarehouse    String?
  total          Decimal        @db.Decimal(10, 2)
  // Гостьові замовлення дозволені: userId NULL. SetNull — видалення юзера не
  // нищить історію замовлень (вони стають гостьовими).
  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  // Адмін-список: keyset-пагінація (createdAt DESC, id DESC) і той самий
  // порядок під фільтром статусу. Окремий @@index([status]) прибрано — він
  // префікс композитного.
  @@index([createdAt(sort: Desc), id(sort: Desc)])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  // Без каскаду: БД не дасть фізично видалити товар з історією замовлень
  // (підкріплює soft delete через Product.isActive).
  product         Product @relation(fields: [productId], references: [id])
  quantity        Int
  // Фіксуємо ціну на момент покупки — історія не залежить від Product.price.
  priceAtPurchase Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([productId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  // Отримувач. onDelete: Cascade — видалення користувача прибирає його
  // сповіщення (вони безглузді без власника).
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  isRead    Boolean          @default(false)
  // Куди вести по кліку, напр. "/my/appointments" чи "/admin/orders".
  link      String?
  createdAt DateTime         @default(now())

  // Швидкий запит непрочитаних користувача в хронологічному порядку.
  @@index([userId, isRead, createdAt])
}
