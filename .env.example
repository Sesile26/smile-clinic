# ─── Database ────────────────────────────────────────────────────────────────
# Local: local Postgres. Production/cloud (Neon): pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/smile_clinic?sslmode=require"
# Direct (non-pooling) connection string — used for prisma migrate deploy / db seed.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/smile_clinic?sslmode=require"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your-auth-secret"
# Canonical app URL (localhost in dev, production domain in prod, no trailing slash)
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-your-secret"

# ─── Roles (email allowlist, comma-separated) ────────────────────────────────
AUTH_ADMIN_EMAILS="admin@example.com"
AUTH_STAFF_EMAILS="staff1@example.com,staff2@example.com"
# AUTH_DOCTOR_EMAILS="doctor1@example.com"   # if used

# ─── Nova Poshta ─────────────────────────────────────────────────────────────
# Nova Poshta account → Settings → Security → Create key
NOVA_POSHTA_API_KEY="your-nova-poshta-key"

# ─── Vercel Blob (product images) ────────────────────────────────────────────
# Provided by the Vercel integration in production; locally via vercel env pull or set manually
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your-token"
BLOB_STORE_ID="store_your-id"

# ─── Optional (have defaults) ────────────────────────────────────────────────
# MAX_ACTIVE_APPOINTMENTS=4
# BOOKING_RATE_LIMIT=5
# BOOKING_RATE_WINDOW_MS=60000