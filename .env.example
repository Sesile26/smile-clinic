# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/smile_clinic?schema=public"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="your-secret-here"

# Canonical app URL (used for OAuth redirect URI construction)
# Development: omit or set to http://localhost:3000
# Production:  set to https://yourdomain.com
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Staff allowlist ─────────────────────────────────────────────────────────
# Comma-separated emails that receive ADMIN role on first sign-in.
AUTH_ADMIN_EMAILS="admin@smileclinic.ua"

# Comma-separated emails that receive STAFF role on first sign-in.
# (Users in AUTH_ADMIN_EMAILS take precedence — no need to repeat them here.)
AUTH_STAFF_EMAILS="doctor1@smileclinic.ua,doctor2@smileclinic.ua,reception@smileclinic.ua"
