# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/smile_clinic?schema=public"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate a new value with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="generate-with-npx-auth-secret"

# Canonical app URL (used for OAuth redirect URI construction)
# Development: http://localhost:3000
# Production:  https://yourdomain.com
AUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-your-secret"

# ─── Role allowlists ─────────────────────────────────────────────────────────
# Comma-separated emails that receive ADMIN role on first (Google) sign-in.
AUTH_ADMIN_EMAILS="admin@example.com,admin@smileclinic.test"

# Comma-separated emails that receive STAFF role on first sign-in.
# (Users in AUTH_ADMIN_EMAILS take precedence — no need to repeat them here.)
AUTH_STAFF_EMAILS="staff1@example.com,staff@smileclinic.test"

# Comma-separated emails that receive DOCTOR role on first sign-in.
# NOTE: role only — linking the User to a Doctor row (Doctor.userId) is a
# separate deliberate step (done by the seed or an admin). Keep in sync with
# the seed accounts so DOCTOR/STAFF/ADMIN sign-ins resolve their role.
AUTH_DOCTOR_EMAILS="doctor@smileclinic.test"

# ─── Nova Poshta ─────────────────────────────────────────────────────────────
# API key for city/warehouse lookups (server-side proxy /api/nova-poshta).
# Get one at https://new.novaposhta.ua → Settings → API. Without it, Nova
# Poshta delivery selection is disabled in checkout (pickup still works).
NOVA_POSHTA_API_KEY="your-nova-poshta-key"

# ─── Vercel Blob (product image uploads) ─────────────────────────────────────
# Public store for product photos (server upload via /api/admin/products/upload).
# Local: copy from your Vercel project's Blob store. Production: injected
# automatically by the Vercel Blob integration. The @vercel/blob SDK reads
# BLOB_READ_WRITE_TOKEN from the environment — never hardcode it.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"
BLOB_STORE_ID="store_xxxxxxxxxxxx"

# ─── Booking tuning (OPTIONAL — sane defaults if unset) ──────────────────────
# Read in app/api/bookings/route.ts. Leave unset to use the defaults shown.
# MAX_ACTIVE_APPOINTMENTS="4"      # max simultaneous active appointments per patient
# BOOKING_RATE_LIMIT="5"           # booking attempts allowed per window
# BOOKING_RATE_WINDOW_MS="60000"   # rate-limit window in ms (in-memory, per-instance)
